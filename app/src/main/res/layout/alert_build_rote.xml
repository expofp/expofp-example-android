<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingTop="16sp"
    android:paddingLeft="16sp"
    android:paddingRight="16sp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/fromTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:minWidth="60sp"
        android:minHeight="40sp"
        android:text="From:"
        android:textAlignment="textStart"
        android:textSize="18sp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@+id/fromEditText"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/fromEditText"
        android:inputType="number|numberDecimal|numberSigned"
        android:layout_width="wrap_content"
        android:minWidth="200sp"
        android:layout_height="40sp"
        app:layout_constraintLeft_toRightOf="@+id/fromTextView"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:hint="Latitude" />
    <TextView
        android:id="@+id/toTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minHeight="40sp"
        android:minWidth="60sp"
        android:text="To:"
        android:textSize="18sp"
        android:textAlignment="textStart"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toBottomOf="@id/fromTextView"
        app:layout_constraintRight_toLeftOf="@+id/toEditText"/>
    <EditText
        android:id="@+id/toEditText"
        android:inputType="number|numberDecimal|numberSigned"
        android:layout_width="wrap_content"
        android:minWidth="200sp"
        android:layout_height="40sp"
        app:layout_constraintLeft_toRightOf="@+id/toTextView"
        app:layout_constraintTop_toBottomOf="@id/fromEditText"
        app:layout_constraintRight_toRightOf="parent"
        android:hint="Longitude" />
</androidx.constraintlayout.widget.ConstraintLayout>
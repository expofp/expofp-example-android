<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingTop="16sp"
    android:paddingLeft="16sp"
    android:paddingRight="16sp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:id="@+id/exhibitorTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:minHeight="40sp"
        android:minWidth="60sp"
        android:text="Exhibitor:"
        android:textSize="18sp"
        android:layout_marginTop="6sp"
        android:textAlignment="textStart"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toLeftOf="@+id/exhibitorEditText"/>
    <EditText
        android:id="@+id/exhibitorEditText"
        android:inputType="text"
        android:layout_width="wrap_content"
        android:minWidth="200sp"
        android:layout_height="40sp"
        app:layout_constraintLeft_toRightOf="@+id/exhibitorTextView"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:hint="Exhibitor name" />
</androidx.constraintlayout.widget.ConstraintLayout>